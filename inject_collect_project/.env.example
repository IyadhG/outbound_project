# ===================================
# Neo4j Configuration (AuraDB)
# ===================================
# Neo4j connection URI (Neo4j Aura format)
NEO4J_URI=neo4j+s://your-cluster-id.databases.neo4j.io

# Neo4j authentication
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here

# ===================================
# API Keys & Credentials
# ===================================
# Google Gemini API Key (for AI-powered data extraction)
GEMINI_API_KEY=your-gemini-api-key-here

# Apollo.io API Key (for company discovery and enrichment)
APOLLO_API_KEY=your-apollo-api-key-here

# ===================================
# Persona Enrichment APIs (for contact discovery)
# ===================================
# Serper API Key (for search-based persona discovery)
SERPER_API_KEY=your-serper-api-key-here

# Hunter.io API Key (primary email finder)
HUNTER_API_KEY=your-hunter-api-key-here

# Snov.io Credentials (secondary email search)
SNOVIO_CLIENT_ID=your-snovio-client-id-here
SNOVIO_CLIENT_SECRET=your-snovio-client-secret-here

# Tomba.io Credentials (email verification)
TOMBA_API_KEY=your-tomba-api-key-here
TOMBA_API_SECRET=your-tomba-api-secret-here

# AeroLeads API Key (LinkedIn & phone enrichment)
AEROLEADS_API_KEY=your-aeroleads-api-key-here

# ===================================
# Application Configuration
# ===================================
# Use local Neo4j instead of AuraDB (set to true if using docker-compose neo4j service)
USE_LOCAL_NEO4J=false

# Local Neo4j configuration (if USE_LOCAL_NEO4J=true)
LOCAL_NEO4J_URI=bolt://neo4j:7687
LOCAL_NEO4J_USER=neo4j
LOCAL_NEO4J_PASSWORD=password123

# ===================================
# Logging & Debug
# ===================================
# Set to DEBUG for verbose output
LOG_LEVEL=INFO

# ===================================
# Processing Configuration
# ===================================
# Max concurrent scraping requests
MAX_CONCURRENT_REQUESTS=5

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Retry attempts for failed requests
MAX_RETRIES=3
